      if (question.includes('spelling') || question.includes('typo') || question.includes('mistakes') || question.includes('grammar')) {
        return `**Don't Worry About Spelling! ✍️**

**WeatherWise AI is Forgiving:**
I can understand questions even with:

✅ **Spelling mistakes**
• "waether" → weather
• "tommorow" → tomorrow
• "humitidy" → humidity
• "forcast" → forecast

✅ **Typos**
• "whats teh weather" → "what's the weather"
• "will ti rain" → "will it rain"

✅ **Grammar issues**
• "weather today what"
• "rain it will tomorrow?"
• "tell about monsoon"

✅ **Casual language**
• "gonna rain?"
• "wanna know weather"
• "temps today?"

✅ **Abbreviations**
• "temp" → temperature
• "humid" → humidity
• "precip" → precipitation
• "mph/kph" → wind speed

**How It Works:**
🤖 AI processes natural language
🔍 Identifies intent over exact words
🧠 Understands context
✨ Focuses on meaning

**Examples That Work:**

❌ **With Mistakes:**
"waht is wheather in pnom penh?"

✅ **Still Understands:**
Gives Phnom Penh weather info!

**Tips:**
• Just type naturally
• Don't stress about perfection
• Fix typos if you notice them
• But no pressure!
• Focus on your question

**When It Might Not Understand:**
• Completely jumbled words
• Missing key terms
• Extremely shortened text
• Mixed languages mid-sentence

**If I Don't Understand:**
I'll ask you to rephrase! Just try saying it differently. 😊

**Bottom Line:**
Focus on what you want to know, not perfect spelling! I'm here to help, not judge! 💙`;
      }

      // Current weather responses
      if (question.includes('today') || question.includes('current') || question.includes('now')) {
        const weather = currentWeather.value;
        if (weather) {
          const temp = Math.round(weather.main.temp);
          const desc = weather.weather[0].description;
          const humidity = weather.main.humidity;
          const wind = weather.wind.speed.toFixed(1);
          
          return `**Today's Weather:**

🌡️ **Temperature:** ${temp}°C
☁️ **Conditions:** ${desc.charAt(0).toUpperCase() + desc.slice(1)}
💧 **Humidity:** ${humidity}%
🌬️ **Wind Speed:** ${wind} m/s

${temp > 32 ? '⚠️ It\'s quite hot today! Stay hydrated and avoid prolonged sun exposure.' : ''}
${humidity > 80 ? '💦 High humidity today - expect it to feel warmer than the actual temperature.' : ''}

Would you like to know about the forecast for the coming days?`;
        }
        return `I can provide current weather information once location data is loaded. Try searching for a location first!`;
      }

      // Forecast responses
      if (question.includes('forecast') || question.includes('tomorrow') || question.includes('week') || question.includes('coming days')) {
        if (forecast.value?.list) {
          const days = {};
          forecast.value.list.slice(0, 8).forEach(item => {
            const day = moment(item.dt_txt).format('ddd');
            if (!days[day]) {
              days[day] = {
                temp: Math.round(item.main.temp),
                desc: item.weather[0].description,
                rain: Math.round((item.pop || 0) * 100)
              };
            }
          });

          let forecastText = '**7-Day Forecast:**\n\n';
          Object.keys(days).forEach(day => {
            const data = days[day];
            forecastText += `📅 **${day}:** ${data.temp}°C, ${data.desc} (${data.rain}% rain)\n`;
          });

          forecastText += '\n💡 **Tip:** Pack an umbrella if rain probability is above 50%!';
          return forecastText;
        }
        return 'Forecast data is being loaded. Please try again in a moment!';
      }

      // Monsoon information
      if (question.includes('monsoon') || question.includes('wet season') || question.includes('dry season') || question.includes('rainy')) {
        return `**Cambodia's Monsoon Seasons:**

🌧️ **Wet Season (May - October)**
• Southwest monsoon brings heavy rainfall
• Peak rainfall: August - September
• Average temp: 27-35°C
• High humidity (80-90%)
• Afternoon thunderstorms common

☀️ **Dry Season (November - April)**
• Cool dry period: November - February
• Hot dry period: March - April
• Less rainfall (occasional showers)
• Lower humidity (60-70%)
• Best time for outdoor activities

**Current Month (December):** We're in the dry season! Expect pleasant weather with cooler temperatures and low rainfall.

💡 **Travel Tip:** The dry season is ideal for visiting Angkor Wat and coastal areas!`;
      }

      // Safety tips
      if (question.includes('safety') || question.includes('protect') || question.includes('dangerous') || question.includes('thunderstorm') || question.includes('flood') || question.includes('heat')) {
        return `**Weather Safety Tips for Cambodia:**

⛈️ **Thunderstorm Safety:**
• Seek shelter in a sturdy building
• Avoid trees, water, and metal objects
• Unplug electronics during lightning
• Wait 30 minutes after last thunder before going out

🌊 **Flood Safety:**
• Never drive through floodwater
• Move to higher ground immediately
• Avoid riverbanks and drainage areas
• Follow evacuation orders promptly

🔥 **Extreme Heat Safety:**
• Stay indoors 11 AM - 3 PM (hottest hours)
• Drink plenty of water (even if not thirsty)
• Wear light-colored, loose clothing
• Check on elderly neighbors

💨 **Strong Wind Safety:**
• Secure outdoor furniture and items
• Stay away from windows
• Avoid tall trees and structures
• Be cautious of falling debris

📞 **Emergency Numbers:**
• Emergency: 119
• Fire & Rescue: 666
• Police: 117
• Disaster Management: 1294

Stay safe and always prioritize your well-being!`;
      }

      // Weather maps
      if (question.includes('map') || question.includes('radar') || question.includes('read') || question.includes('understand')) {
        return `**How to Read Weather Maps:**

🗺️ **Temperature Maps:**
• **Red/Orange:** Hot zones (30°C+)
• **Yellow/Green:** Moderate (25-30°C)
• **Blue/Purple:** Cool zones (<25°C)
• Isotherms show temperature boundaries

☔ **Precipitation Maps:**
• **Light Blue/Green:** Light rain
• **Dark Blue:** Moderate rain
• **Purple:** Heavy rainfall
• Radar shows rain intensity in real-time

🌀 **Pressure Systems:**
• **H (High Pressure):** Clear, calm weather
• **L (Low Pressure):** Clouds, possible storms
• Isobars show pressure gradients
• Closer lines = stronger winds

🎯 **Reading Tips:**
• Check legend for color meanings
• Look for patterns and fronts
• Monitor time stamps for currency
• Compare multiple layers for complete picture

Try our interactive weather map below to practice!`;
      }

      // Weather phenomena
      if (question.includes('typhoon') || question.includes('hurricane') || question.includes('cyclone') || question.includes('storm')) {
        return `**Tropical Cyclones in Cambodia:**

🌀 **What They Are:**
Typhoons (called hurricanes in other regions) are powerful tropical storms with winds exceeding 119 km/h. They form over warm ocean waters.

📍 **Cambodia's Risk:**
• Cambodia is generally **protected** from direct typhoon hits
• Located west of the main typhoon belt
• May experience **remnants** of storms from South China Sea
• Coastal areas (Sihanoukville) most vulnerable

⚠️ **Typhoon Season:**
• Peak: July - November
• Most storms affect Vietnam/Philippines
• Cambodia gets heavy rain from distant typhoons

🛡️ **Preparation:**
• Monitor weather forecasts regularly
• Stock emergency supplies (food, water, batteries)
• Secure outdoor items
• Know evacuation routes
• Keep phone charged

**Recent History:** Cambodia rarely experiences direct typhoon strikes, but heavy rainfall from nearby systems can cause flooding in low-lying areas.`;
      }

      // Weather terms
      if (question.includes('humidity') || question.includes('pressure') || question.includes('uv index') || question.includes('dew point') || question.includes('what is')) {
        if (question.includes('humidity')) {
          return `**Understanding Humidity:**

💧 **What is Humidity?**
The amount of water vapor in the air, expressed as a percentage. 100% means the air is fully saturated.

📊 **Comfort Levels:**
• **<30%:** Very dry (can cause dry skin)
• **30-50%:** Comfortable
• **50-70%:** Slightly humid
• **70-85%:** Humid (feels muggy)
• **>85%:** Very humid (uncomfortable)

🌡️ **Why It Matters:**
• High humidity makes heat feel worse
• Affects how your body cools through sweat
• Influences cloud formation and rain
• Impacts mold growth and air quality

🇰🇭 **Cambodia's Humidity:**
• Wet Season: 80-90% (very humid!)
• Dry Season: 60-70% (more comfortable)

Current conditions show above for your location!`;
        }
        
        if (question.includes('pressure') || question.includes('barometric')) {
          return `**Atmospheric Pressure Explained:**

🔬 **What is It?**
The weight of air pressing down on Earth's surface, measured in hectopascals (hPa) or millibars (mb).

📊 **Pressure Ranges:**
• **High Pressure (>1020 hPa):** Clear, calm weather
• **Normal (1013 hPa):** Standard sea level pressure
• **Low Pressure (<1000 hPa):** Clouds, possible storms

☁️ **How It Affects Weather:**
• Rising pressure → Improving weather
• Falling pressure → Worsening conditions
• Rapid drops → Storms approaching

🎣 **Fun Fact:**
Fishermen watch pressure changes! Low pressure makes fish more active and easier to catch.

**Your Location:** Check the current pressure in the weather highlights section!`;
        }

        if (question.includes('uv') || question.includes('ultraviolet')) {
          return `**UV Index Guide:**

☀️ **What is UV Index?**
Measures ultraviolet radiation intensity from the sun. Higher numbers = greater sunburn risk.

📊 **UV Index Scale:**
• **0-2 (Low):** Minimal protection needed
• **3-5 (Moderate):** Wear sunscreen
• **6-7 (High):** Sunscreen + hat required
• **8-10 (Very High):** Extra protection needed
• **11+ (Extreme):** Avoid sun if possible

⏰ **Peak Hours:**
10 AM - 4 PM is when UV radiation is strongest

🧴 **Protection Tips:**
• Use SPF 30+ sunscreen
• Reapply every 2 hours
• Wear sunglasses (UV protection)
• Seek shade during peak hours
• Wear protective clothing

🇰🇭 **Cambodia UV Levels:**
Often reach 8-11 (Very High to Extreme) during dry season, especially March-April!`;
        }
      }

