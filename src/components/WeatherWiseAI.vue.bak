<template>
  <div class="weatherwise-ai-container">
    <!-- AI Chatbot Card -->
    <div class="ai-chatbot-card">
      <!-- Header -->
      <div class="chat-header">
        <div class="header-logo">
          <div class="logo-icon">
            <i class="fas fa-cloud-sun"></i>
          </div>
          <div class="header-title">
            <h2>WeatherWise AI</h2>
            <p>AI Weather Assistant - Powered by Claude</p>
          </div>
        </div>
      </div>

      <!-- Animated Background -->
      <div class="clouds-background">
        <div class="cloud cloud1"></div>
        <div class="cloud cloud2"></div>
        <div class="cloud cloud3"></div>
      </div>

      <!-- Main Search/Ask Section -->
      <div class="main-search-section">
        <div class="search-container">
          <div class="search-icon">
            <i class="fas fa-search"></i>
          </div>
          <input 
            v-model="userInput" 
            type="text" 
            class="main-search-input" 
            placeholder="Search or ask about weather conditions..."
            @keypress.enter="sendMessage"
            @focus="onSearchFocus"
            :disabled="isTyping"
            ref="inputField"
          />
          <button 
            class="main-send-btn" 
            @click="sendMessage" 
            :disabled="isTyping || !userInput.trim()"
            :class="{ 'active': userInput.trim() }"
          >
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
        <div class="search-suggestions" v-if="showSuggestions">
          <button class="suggestion-chip" @click="useSuggestion('What\'s the weather today?')">
            <i class="fas fa-sun"></i> What's the weather today?
          </button>
          <button class="suggestion-chip" @click="useSuggestion('Will it rain tomorrow?')">
            <i class="fas fa-cloud-rain"></i> Will it rain tomorrow?
          </button>
          <button class="suggestion-chip" @click="useSuggestion('Temperature forecast for this week')">
            <i class="fas fa-temperature-high"></i> Temperature forecast
          </button>
          <button class="suggestion-chip" @click="useSuggestion('What is the air quality?')">
            <i class="fas fa-wind"></i> Air quality
          </button>
        </div>
      </div>

      <!-- Chat Messages Area -->
      <div class="chat-messages" ref="messagesContainer">
        <div v-for="(message, index) in messages" :key="index" :class="['message', message.type]">
          <div class="message-avatar" v-if="message.type === 'bot'">
            <i class="fas fa-cloud-sun"></i>
          </div>
          <div class="message-content">
            <div class="message-bubble" v-html="formatMessage(message.text)"></div>
            <div class="message-time">{{ message.time }}</div>
          </div>
          <div class="message-avatar" v-if="message.type === 'user'">
            <i class="fas fa-user"></i>
          </div>
        </div>

        <!-- Typing Indicator -->
        <div v-if="isTyping" class="message bot">
          <div class="message-avatar">
            <i class="fas fa-cloud-sun"></i>
          </div>
          <div class="message-content">
            <div class="typing-indicator">
              <span></span>
              <span></span>
              <span></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Main Action Buttons -->
      <div class="main-action-buttons">
        <button class="main-action-btn ask-btn" @click="showAskMode">
          <div class="btn-icon">
            <i class="fas fa-comments"></i>
          </div>
          <div class="btn-content">
            <h3>Ask</h3>
            <p>Quick weather questions</p>
          </div>
        </button>
        <button class="main-action-btn research-btn" @click="showResearchMode">
          <div class="btn-icon">
            <i class="fas fa-search"></i>
          </div>
          <div class="btn-content">
            <h3>Research</h3>
            <p>Deep weather analysis</p>
          </div>
        </button>
      </div>

      <!-- Quick Action Buttons (shown in Ask mode) -->
      <div v-if="mode === 'ask'" class="quick-actions">
        <button class="action-btn" @click="sendQuickAction('today')">
          <i class="fas fa-sun"></i>
          <span>Today's Weather</span>
        </button>
        <button class="action-btn" @click="sendQuickAction('monsoon')">
          <i class="fas fa-cloud-rain"></i>
          <span>Monsoon Info</span>
        </button>
        <button class="action-btn" @click="sendQuickAction('safety')">
          <i class="fas fa-shield-alt"></i>
          <span>Safety Tips</span>
        </button>
        <button class="action-btn" @click="sendQuickAction('maps')">
          <i class="fas fa-map"></i>
          <span>Weather Maps</span>
        </button>
      </div>

      <!-- Research Topics (shown in Research mode) -->
      <div v-if="mode === 'research'" class="research-topics">
        <button class="research-topic-btn" @click="sendResearchTopic('climate')">
          <i class="fas fa-globe-asia"></i>
          <span>Climate Patterns</span>
        </button>
        <button class="research-topic-btn" @click="sendResearchTopic('historical')">
          <i class="fas fa-history"></i>
          <span>Historical Data</span>
        </button>
        <button class="research-topic-btn" @click="sendResearchTopic('forecast')">
          <i class="fas fa-chart-line"></i>
          <span>Forecast Analysis</span>
        </button>
        <button class="research-topic-btn" @click="sendResearchTopic('science')">
          <i class="fas fa-flask"></i>
          <span>Weather Science</span>
        </button>
      </div>
    </div>
  </div>
</template>

<script>
import { ref, computed, nextTick, onMounted } from 'vue';
import { useStore } from 'vuex';
import moment from 'moment';

export default {
  name: 'WeatherWiseAI',
  setup() {
    const store = useStore();
    const messages = ref([]);
    const userInput = ref('');
    const isTyping = ref(false);
    const messagesContainer = ref(null);
    const inputField = ref(null);
    const mode = ref(null); // 'ask' or 'research'
    const showSuggestions = ref(false);
    const conversationContext = ref({
      lastTopic: null,
      askedAboutRain: false,
      askedAboutTemp: false,
      locationSet: false
    });

    const currentWeather = computed(() => store.state.currentWeather);
    const forecast = computed(() => store.state.forecast);

    // Initialize with welcome message
    onMounted(() => {
      addMessage('bot', `Hello! I'm WeatherWise AI - your intelligent weather assistant! 🌤️

**🤖 How I Work:**
I use advanced Natural Language Processing to:
1. 📝 Understand your question
2. 📍 Extract location & date information
3. 🌐 Fetch real-time weather data
4. 💬 Provide human-friendly answers

**Ask me naturally like:**
• "What's the weather in Phnom Penh?"
• "Will it rain tomorrow?"
• "Temperature in London next week"
• "Should I bring an umbrella?"

Try asking me anything about the weather! 🚀`);
    });

    const onSearchFocus = () => {
      showSuggestions.value = true;
    };

    const useSuggestion = (suggestion) => {
      userInput.value = suggestion;
      showSuggestions.value = false;
      sendMessage();
    };

    const showAskMode = () => {
      mode.value = 'ask';
      addMessage('bot', `**Ask Mode Activated** 💬

I'm ready for your quick weather questions! You can:
• Ask about current conditions
• Get weather forecasts
• Learn safety tips
• Understand weather patterns

Use the quick buttons below or type your own question!`);
    };

    const showResearchMode = () => {
      mode.value = 'research';
      addMessage('bot', `**Research Mode Activated** 🔬

Let's explore weather science in depth! Choose a research topic:
• Climate Patterns - Long-term weather trends
• Historical Data - Past weather events
• Forecast Analysis - Prediction methods
• Weather Science - How it all works

Select a topic or ask your own research question!`);
    };

    const sendResearchTopic = (topic) => {
      const topics = {
        climate: "Tell me about Cambodia's climate patterns and seasonal changes",
        historical: "What are some notable historical weather events in Cambodia?",
        forecast: "How do weather forecasts work and how accurate are they?",
        science: "Explain the science behind weather formation and changes"
      };
      
      userInput.value = topics[topic];
      sendMessage();
    };

    const addMessage = (type, text) => {
      messages.value.push({
        type,
        text,
        time: moment().format('hh:mm A')
      });
      nextTick(() => {
        if (messagesContainer.value) {
          messagesContainer.value.scrollTop = messagesContainer.value.scrollHeight;
        }
      });
    };

    const formatMessage = (text) => {
      // Convert markdown-style formatting to HTML with enhanced styling
      return text
        .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
        .replace(/\*(.*?)\*/g, '<em>$1</em>')
        .replace(/\n/g, '<br>')
        .replace(/•/g, '<span class="bullet">•</span>')
        .replace(/🌡️|☀️|🌧️|💧|💨|☁️|⛅|🌤️|🔥|❄️|🍃|🧥|☂️|📊|📅|⏰|📍|🔍|🌍/g, '<span class="emoji">$&</span>');
    };

    const sendMessage = async () => {
      const message = userInput.value.trim();
      if (!message) return;

      showSuggestions.value = false;
      
      // Track conversation context
      if (message.match(/rain/i)) conversationContext.value.askedAboutRain = true;
      if (message.match(/temp|hot|cold|warm/i)) conversationContext.value.askedAboutTemp = true;
      if (currentWeather.value) conversationContext.value.locationSet = true;
      
      addMessage('user', message);
      userInput.value = '';
      isTyping.value = true;

      try {
        // Step 1: AI NLP Processing - Extract location and date
        const extractedInfo = extractLocationAndDate(message);
        
        // Step 2: Fetch Weather API data if location is extracted
        if (extractedInfo.location && extractedInfo.location !== 'current') {
          // Show AI is processing location
          const processingMsg = `🔍 *Searching weather data for ${extractedInfo.location}...*`;
          addMessage('bot', processingMsg);
          
          await store.dispatch('searchWeather', extractedInfo.location);
          // Small delay to ensure data is loaded
          await new Promise(resolve => setTimeout(resolve, 500));
          
          // Remove the processing message
          messages.value.pop();
        }
        
        // Step 3: AI Interpretation & Human-friendly response
        await new Promise(resolve => setTimeout(resolve, 800 + Math.random() * 1200));
        const response = await getSmartAIResponse(message.toLowerCase(), message, extractedInfo);
        
        isTyping.value = false;
        addMessage('bot', response);
      } catch (error) {
        isTyping.value = false;
        addMessage('bot', `I encountered an issue processing your request. Please try again or rephrase your question. 🔄`);
        console.error('AI Error:', error);
      }
    };

    // Step 1: NLP - Extract Location and Date from User Question
    const extractLocationAndDate = (question) => {
      const result = {
        location: null,
        date: null,
        dateType: 'current' // current, today, tomorrow, specific
      };

      // Date extraction
      const datePatterns = {
        today: /\b(today|now|current|right now)\b/i,
        tomorrow: /\btomorrow\b/i,
        thisWeek: /\b(this week|next week|coming week)\b/i,
        specific: /\b(monday|tuesday|wednesday|thursday|friday|saturday|sunday|january|february|march|april|may|june|july|august|september|october|november|december|\d{1,2}\/\d{1,2}|\d{1,2}-\d{1,2})\b/i
      };

      if (datePatterns.tomorrow.test(question)) {
        result.date = moment().add(1, 'day');
        result.dateType = 'tomorrow';
      } else if (datePatterns.thisWeek.test(question)) {
        result.date = moment().add(3, 'days');
        result.dateType = 'week';
      } else if (datePatterns.specific.test(question)) {
        result.dateType = 'specific';
        // Extract specific date
        const match = question.match(datePatterns.specific);
        if (match) result.date = match[0];
      } else if (datePatterns.today.test(question)) {
        result.date = moment();
        result.dateType = 'today';
      }

      // Location extraction - Common city patterns
      const locationPatterns = [
        /\bin ([A-Z][a-z]+(?:\s[A-Z][a-z]+)*)/,
        /\bat ([A-Z][a-z]+(?:\s[A-Z][a-z]+)*)/,
        /\bfor ([A-Z][a-z]+(?:\s[A-Z][a-z]+)*)/,
        /([A-Z][a-z]+(?:\s[A-Z][a-z]+)*)'s weather/,
        /weather (?:in|at|for) ([A-Z][a-z]+(?:\s[A-Z][a-z]+)*)/i
      ];

      for (const pattern of locationPatterns) {
        const match = question.match(pattern);
        if (match && match[1]) {
          result.location = match[1];
          break;
        }
      }

      // Common city names (lowercase check)
      const commonCities = ['phnom penh', 'siem reap', 'battambang', 'london', 'paris', 'tokyo', 'new york', 'bangkok', 'singapore', 'hanoi'];
      const lowerQuestion = question.toLowerCase();
      for (const city of commonCities) {
        if (lowerQuestion.includes(city)) {
          result.location = city.split(' ').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
          break;
        }
      }

      // If no location found but weather data exists, use current
      if (!result.location && currentWeather.value) {
        result.location = 'current';
      }

      return result;
    };

    const sendQuickAction = (action) => {
      const actions = {
        today: "What's the weather like today?",
        monsoon: "Tell me about Cambodia's monsoon season",
        safety: "What are some weather safety tips?",
        maps: "How do I read weather maps?"
      };
      
      userInput.value = actions[action];
      sendMessage();
    };

    // Enhanced Smart AI Response System with Location & Date awareness
    const getSmartAIResponse = async (question, originalQuestion, extractedInfo = {}) => {
      const weather = currentWeather.value;
      const forecastData = forecast.value;

      // Show location awareness if location was extracted
      let locationContext = '';
      if (extractedInfo.location && extractedInfo.location !== 'current') {
        locationContext = `*Analyzing weather for ${extractedInfo.location}...*\n\n`;
      }

      // Show date awareness if date was extracted
      let dateContext = '';
      if (extractedInfo.dateType === 'tomorrow') {
        dateContext = '**Tomorrow\'s Weather:**\n';
      } else if (extractedInfo.dateType === 'week') {
        dateContext = '**This Week\'s Weather:**\n';
      } else if (extractedInfo.dateType === 'today') {
        dateContext = '**Today\'s Weather:**\n';
      }

      // Current Weather Questions
      if (question.match(/what('?s| is)? (the )?weather|current (weather|conditions?)|weather (now|today|right now)/i)) {
        if (weather && weather.main) {
          const temp = weather.main.temp.toFixed(1);
          const feelsLike = weather.main.feels_like.toFixed(1);
          const desc = weather.weather[0].description;
          const humidity = weather.main.humidity;
          const windSpeed = weather.wind.speed;
          const location = weather.name;

          return `${locationContext}${dateContext}**Weather in ${location}** 🌤️

🌡️ **Temperature:** ${temp}°C (feels like ${feelsLike}°C)
☁️ **Conditions:** ${desc.charAt(0).toUpperCase() + desc.slice(1)}
💧 **Humidity:** ${humidity}%
💨 **Wind:** ${windSpeed} m/s

${getWeatherAdvice(temp, desc, humidity)}

*Want to know more? Ask about tomorrow's forecast or specific conditions!*`;
        }
        return `${locationContext}I'd love to tell you about the weather! Please search for a location first using the search bar at the top. 🌍`;
      }

      // Temperature Questions with Date awareness
      if (question.match(/temperature|how (hot|cold|warm)|temp|degrees/i)) {
        if (extractedInfo.dateType === 'tomorrow' && forecastData && forecastData.list) {
          const tomorrowData = forecastData.list.slice(8, 16);
          if (tomorrowData.length > 0) {
            const avgTemp = (tomorrowData.reduce((sum, f) => sum + f.main.temp, 0) / tomorrowData.length).toFixed(1);
            const maxTemp = Math.max(...tomorrowData.map(f => f.main.temp)).toFixed(1);
            const minTemp = Math.min(...tomorrowData.map(f => f.main.temp)).toFixed(1);
            
            return `${locationContext}**Tomorrow's Temperature Forecast** 🌡️

📊 **Expected Range:** ${minTemp}°C to ${maxTemp}°C
📈 **Average:** ${avgTemp}°C

${getTempAdvice(parseFloat(avgTemp))}

*Based on 8 forecast points throughout tomorrow. Conditions may vary!*`;
          }
        }
        
        if (weather && weather.main) {
          const temp = weather.main.temp.toFixed(1);
          const feelsLike = weather.main.feels_like.toFixed(1);
          const tempMin = weather.main.temp_min.toFixed(1);
          const tempMax = weather.main.temp_max.toFixed(1);

          return `${locationContext}${dateContext}**Temperature Analysis** 🌡️

🌡️ **Current:** ${temp}°C (feels like ${feelsLike}°C)
📊 **Today's Range:** ${tempMin}°C to ${tempMax}°C

${getTempAdvice(parseFloat(temp))}

💡 *The "feels like" temperature accounts for humidity and wind chill.*`;
        }
        return `${locationContext}To check the temperature, please search for a location first! 📍`;
      }

      // Rain/Precipitation Questions with intelligent date handling
      if (question.match(/rain|precipitation|wet|storm|shower/i)) {
        if (forecastData && forecastData.list) {
          let forecastSlice = forecastData.list.slice(0, 8);
          let timeframe = "next 24 hours";
          
          if (extractedInfo.dateType === 'tomorrow') {
            forecastSlice = forecastData.list.slice(8, 16);
            timeframe = "tomorrow";
          }
          
          const upcomingRain = forecastSlice.filter(f => f.pop && f.pop > 0.3);
          
          if (upcomingRain.length > 0) {
            const nextRain = upcomingRain[0];
            const rainTime = moment(nextRain.dt_txt).format('h:mm A on MMM D');
            const rainChance = Math.round(nextRain.pop * 100);
            
            return `${locationContext}**Rain Forecast for ${timeframe}** 🌧️

⏰ **Expected:** ${rainTime}
💧 **Chance:** ${rainChance}%
📊 **Rain Periods:** ${upcomingRain.length} expected

**Recommendations:**
• ☂️ Bring an umbrella
• 📱 Check updates regularly
• 🏠 Consider indoor activities for heavy rain

*Forecasts can change - check back for updates!*`;
          } else {
            return `${locationContext}**No Rain Expected** ☀️

Good news! No significant rain forecasted for ${timeframe}.

Perfect weather for outdoor activities! 🎉`;
          }
        }
        return `${locationContext}Let me check the rain forecast! Please search for a location first. 🔍`;
      }

      // Forecast Questions with smart date handling
      if (question.match(/forecast|tomorrow|next (day|week|few days)|coming days|will it|gonna/i)) {
        if (forecastData && forecastData.list) {
          let forecastSlice = forecastData.list.slice(0, 8);
          let timeframe = "Next 24 Hours";
          
          if (extractedInfo.dateType === 'tomorrow') {
            forecastSlice = forecastData.list.slice(8, 16);
            timeframe = "Tomorrow";
          } else if (extractedInfo.dateType === 'week') {
            forecastSlice = forecastData.list.slice(0, 40);
            timeframe = "This Week";
          }
          
          const avgTemp = (forecastSlice.reduce((sum, f) => sum + f.main.temp, 0) / forecastSlice.length).toFixed(1);
          const conditions = [...new Set(forecastSlice.map(f => f.weather[0].main))];
          const rainChance = Math.max(...forecastSlice.map(f => f.pop || 0)) * 100;
          
          return `${locationContext}**${timeframe} Forecast** 📅

🌡️ **Avg Temperature:** ${avgTemp}°C
☁️ **Conditions:** ${conditions.join(', ')}
💧 **Max Rain Chance:** ${rainChance.toFixed(0)}%

📊 **Detailed View:**
Check the hourly and 5-day forecast cards on the main page for:
• Hour-by-hour changes
• Precipitation timing
• Wind patterns
• Humidity levels

*Ask me about specific conditions for more details!*`;
        }
        return `${locationContext}To see the forecast, please search for a location first! 🌍`;
      }

      // Humidity Questions
      if (question.match(/humidity|humid|moisture|damp/i)) {
        if (weather && weather.main) {
          const humidity = weather.main.humidity;
          let humidityAdvice = '';
          
          if (humidity > 70) {
            humidityAdvice = "**High humidity!** 💧 It may feel uncomfortable and muggy. Stay in air-conditioned spaces when possible.";
          } else if (humidity > 50) {
            humidityAdvice = "**Moderate humidity** - Comfortable conditions for most activities.";
          } else {
            humidityAdvice = "**Low humidity** - Air is dry. Consider using moisturizer and staying hydrated.";
          }

          return `**Humidity Analysis** 💧

**Current Humidity:** ${humidity}%

${humidityAdvice}

**What is humidity?**
Humidity measures the amount of water vapor in the air. Higher humidity makes heat feel more intense and can affect comfort levels.`;
        }
        return `I can check the humidity for you! Please search for a location first. 📍`;
      }

      // Wind Questions
      if (question.match(/wind|windy|breeze|gust/i)) {
        if (weather && weather.wind) {
          const windSpeed = weather.wind.speed;
          const windDeg = weather.wind.deg;
          const direction = getWindDirection(windDeg);
          
          let windAdvice = '';
          if (windSpeed > 10) {
            windAdvice = "**Strong winds!** 💨 Secure loose objects and be cautious when driving.";
          } else if (windSpeed > 5) {
            windAdvice = "**Moderate breeze** - Pleasant wind conditions.";
          } else {
            windAdvice = "**Light winds** - Calm conditions.";
          }

          return `**Wind Analysis** 💨

**Wind Speed:** ${windSpeed} m/s
**Direction:** ${direction} (${windDeg}°)

${windAdvice}

**Wind Speed Reference:**
• 0-2 m/s: Calm
• 2-5 m/s: Light breeze
• 5-10 m/s: Moderate breeze
• 10+ m/s: Strong winds`;
        }
        return `I can check wind conditions! Please search for a location first. 🌍`;
      }

      // Air Quality Questions
      if (question.match(/air quality|aqi|pollution|air pollution/i)) {
        return `**Air Quality Information** 🍃

To check air quality:
1. Look for the "Air Quality Index" card on the main page
2. It shows real-time AQI levels
3. Includes health recommendations
4. Color-coded for easy understanding

**AQI Levels:**
• 0-50: Good (Green)
• 51-100: Moderate (Yellow)
• 101-150: Unhealthy for sensitive groups (Orange)
• 151+: Unhealthy (Red)

Would you like to know about current conditions in your area?`;
      }

      // UV Index Questions
      if (question.match(/uv|sun exposure|sunburn|sun protection/i)) {
        return `**UV Index Information** ☀️

Check the "UV Index" card on the main page for:
• Current UV levels
• Sun protection recommendations
• Best times for sun exposure
• Risk levels throughout the day

**UV Protection Tips:**
• UV 0-2: Low risk
• UV 3-5: Moderate - Use sunscreen
• UV 6-7: High - Seek shade during midday
• UV 8-10: Very High - Extra protection needed
• UV 11+: Extreme - Avoid sun exposure

Stay safe in the sun! 🧴`;
      }

      // Location/Search Questions
      if (question.match(/how (do|to) (search|find|change|set) location|change city|different place/i)) {
        return `**Changing Location** 📍

**Quick Search:**
1. 🔍 Find the search bar at the top
2. 🌍 Type any city name (e.g., "Phnom Penh", "London")
3. ⏎ Press Enter or click Search
4. ✅ Weather updates automatically!

**Tips:**
• Try "City, Country" for better results
• Search works worldwide
• Recent searches are saved
• Current location can be auto-detected

What location would you like to check?`;
      }

      // Fallback with context-aware suggestions
      if (!conversationContext.value.locationSet) {
        return `**Let's Get Started!** 🌍

I noticed you haven't searched for a location yet. To give you accurate weather information:

1. Use the search bar at the top of the page
2. Type any city name
3. Then ask me about the weather!

**In the meantime, you can ask me:**
• How weather forecasts work
• About Cambodia's monsoon season
• Weather safety tips
• How to use this app

What would you like to know?`;
      }

      // If we reach here, try original response system
      return getAIResponse(question);
    };

    // Helper function to get wind direction
    const getWindDirection = (degrees) => {
      const directions = ['North', 'North-East', 'East', 'South-East', 'South', 'South-West', 'West', 'North-West'];
      const index = Math.round(degrees / 45) % 8;
      return directions[index];
    };

    // Helper function to provide weather advice
    const getWeatherAdvice = (temp, description, humidity) => {
      const advice = [];
      
      if (temp > 30) {
        advice.push("☀️ **Hot day ahead!** Stay hydrated, use sunscreen, and avoid midday sun exposure.");
      } else if (temp < 15) {
        advice.push("🧥 **Cool weather!** Consider wearing layers and a jacket.");
      }
      
      if (description.includes('rain')) {
        advice.push("☂️ **Rain expected!** Don't forget your umbrella.");
      } else if (description.includes('cloud')) {
        advice.push("☁️ **Cloudy skies** - Good conditions for outdoor activities without harsh sun.");
      } else if (description.includes('clear')) {
        advice.push("☀️ **Clear skies!** Perfect weather for outdoor plans.");
      }
      
      if (humidity > 70) {
        advice.push("💧 **High humidity** - May feel more uncomfortable than the temperature suggests.");
      }
      
      return advice.length > 0 ? advice.join('\n') : "Conditions look stable!";
    };

    // Helper function for temperature advice
    const getTempAdvice = (temp) => {
      if (temp > 35) {
        return "🔥 **Extremely Hot!** Limit outdoor exposure. Stay in air-conditioned spaces, drink plenty of water.";
      } else if (temp > 30) {
        return "☀️ **Very Warm!** Stay hydrated, use sunscreen SPF 30+, and seek shade during peak hours.";
      } else if (temp > 25) {
        return "😊 **Pleasant & Warm!** Ideal weather for most outdoor activities. Light clothing recommended.";
      } else if (temp > 20) {
        return "👌 **Comfortable!** Perfect temperature for all activities. Enjoy the weather!";
      } else if (temp > 15) {
        return "🍃 **Mild & Cool!** Light jacket recommended. Great for outdoor walks.";
      } else if (temp > 10) {
        return "🧥 **Cool Weather!** Wear layers and a jacket. Hot beverages recommended.";
      } else {
        return "❄️ **Cold!** Bundle up with warm clothing. Limit prolonged outdoor exposure.";
      }
    };

    // Helper function to add contextual follow-up suggestions
    const addFollowUpSuggestions = (response, questionType) => {
      const followUps = {
        temperature: ["\n\n**Want to know more?**\n• Ask about humidity levels\n• Check the hourly forecast\n• Get rain predictions"],
        rain: ["\n\n**Related questions:**\n• What's the temperature?\n• Should I bring an umbrella?\n• Check hourly forecast for timing"],
        forecast: ["\n\n**Dig deeper:**\n• Ask about specific days\n• Check rain chances\n• Get temperature trends"],
        current: ["\n\n**Also check:**\n• Tomorrow's forecast\n• Rain probability\n• UV index and air quality"]
      };
      
      if (followUps[questionType]) {
        return response + followUps[questionType][0];
      }
      return response;
    };

    const getAIResponse = (question) => {
      // Smart greeting detection
      if (question.match(/^(hi|hello|hey|good morning|good afternoon|good evening|greetings|sup|yo|howdy)/i) && question.length < 30) {
        const greetings = [
          "Hello! 👋 How can I help you with weather information today?",
          "Hi there! 🌤️ Ready to explore weather conditions? Ask me anything!",
          "Hey! 😊 What weather information are you looking for?",
          "Greetings! ⛅ I'm here to help with all your weather questions!"
        ];
        return greetings[Math.floor(Math.random() * greetings.length)];
      }

      // Thank you responses
      if (question.match(/^(thank|thanks|thx|appreciate|grateful)/i)) {
        return "You're welcome! 😊 Feel free to ask me anything else about the weather. I'm always here to help! 🌤️";
      }

      // Help/capability questions
      if (question.match(/what can you (do|tell)|how (can|do) you help|capabilities|functions/i)) {
        return `**What I Can Do** 🤖

I'm your intelligent weather assistant! Here's how I can help:

**Current Weather:**
• Temperature and feels-like conditions
• Humidity, wind speed, and direction
• Weather descriptions and conditions
• Real-time updates from your location

**Forecasts:**
• Hourly predictions for the next 24 hours
• 5-day weather outlook
• Rain probability and timing
• Temperature trends

**Analysis & Advice:**
• Personalized weather recommendations
• Safety tips based on conditions
• Best times for outdoor activities
• Weather pattern explanations

**Educational Content:**
• How weather works
• Climate information
• Seasonal patterns (especially Cambodia's monsoons)
• Understanding weather terminology

Just ask me anything naturally - like "Will it rain tomorrow?" or "What's the temperature?" I understand conversational language! 💬`;
      }

      // Smart question detection for complex queries
      if (question.match(/should i|is it (good|bad|safe|okay)|can i|recommend/i)) {
        const weather = currentWeather.value;
        if (weather && weather.main) {
          const temp = weather.main.temp;
          const desc = weather.weather[0].description.toLowerCase();
          
          let recommendation = '';
          if (question.match(/outdoor|outside|park|walk|run|exercise/i)) {
            if (desc.includes('rain') || desc.includes('storm')) {
              recommendation = "**Indoor activities recommended** ☔\n\nIt's rainy outside. Consider postponing outdoor plans or bringing rain gear.";
            } else if (temp > 32) {
              recommendation = "**Exercise caution outdoors** 🌡️\n\nIt's very hot. If going out:\n• Stay hydrated\n• Use sunscreen\n• Avoid midday sun (11 AM - 3 PM)\n• Take frequent breaks";
            } else if (temp > 20 && temp < 30) {
              recommendation = "**Perfect for outdoor activities!** ☀️\n\nGreat weather conditions for:\n• Walking or jogging\n• Outdoor sports\n• Picnics\n• General outdoor activities";
            } else {
              recommendation = "**Comfortable conditions** 👍\n\nWeather looks good for outdoor activities. Just dress appropriately for the temperature.";
            }
            return recommendation;
          }
          
          if (question.match(/umbrella/i)) {
            if (desc.includes('rain') || desc.includes('drizzle')) {
              return "**Yes, bring an umbrella!** ☂️\n\nRain is present or expected. Better to be prepared!";
            } else {
              return "**No umbrella needed** ☀️\n\nNo rain in the current conditions. You should be good to go!";
            }
          }
        }
      }

      // Comparative questions (better/worse/warmer/cooler)
      if (question.match(/(warmer|cooler|hotter|colder|better|worse) than/i)) {
        return `**Weather Comparisons** 📊

I can help compare weather conditions! However, I need you to be more specific:

• Comparing to another day? "How does today compare to yesterday?"
• Comparing to another location? "Is it warmer here than in [city]?"
• Comparing to average? "Is this hotter than normal?"

Please rephrase your question with more details, and I'll give you a detailed comparison!`;
      }

      // Time-based questions (when will, what time)
      if (question.match(/when (will|does)|what time/i)) {
        if (question.match(/rain|storm|precipitation/i)) {
          const forecastData = forecast.value;
          if (forecastData && forecastData.list) {
            const nextRain = forecastData.list.find(f => f.weather[0].main.toLowerCase().includes('rain'));
            if (nextRain) {
              const rainTime = moment(nextRain.dt_txt).format('h:mm A on MMM D');
              return `**Rain Timing** 🌧️\n\nRain is expected around ${rainTime}.\n\nKeep an eye on updates as weather can change!`;
            } else {
              return `**No Rain Expected** ☀️\n\nI don't see rain in the forecast for the next few days. Looks like clear skies ahead!`;
            }
          }
        }
        
        if (question.match(/sunrise|sunset|sun/i)) {
          return `**Sun Timing** 🌅\n\nFor sunrise and sunset times, check the "Sunrise & Sunset" card on the main page!\n\nIt shows:\n• Exact sunrise time\n• Exact sunset time\n• Daylight duration\n• Beautiful visualizations`;
        }
      }

      // General Questions (Q1-Q5)
      if (question.includes('what is weatherwise') || question.includes('about weatherwise') || question.includes('tell me about this')) {
        return `**What is WeatherWise AI?**

WeatherWise AI is your intelligent weather assistant powered by advanced AI technology! 🌤️

**Key Features:**
• 🎯 Real-time weather information
• 📊 7-day forecasts and trends
• 🇰🇭 Cambodia-specific expertise
• 💬 Conversational interface
• 📚 Educational weather content
• 🆓 Completely free to use

**Perfect For:**
• Daily weather planning
• Learning about weather science
• Understanding monsoon patterns
• Travel planning
• Agricultural planning
• Educational purposes

It's designed to make weather information accessible, educational, and conversational for everyone! No account needed - just start asking questions! 😊`;
      }

      if (question.includes('who created') || question.includes('who made') || question.includes('developer')) {
        return `**About WeatherWise AI**

